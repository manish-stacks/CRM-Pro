# ============ DATABASE ============
DATABASE_URL="mysql://root:password@localhost:3306/hbs_crm"

# ============ AUTH ============
JWT_SECRET="change-this-to-a-random-32-plus-char-string-in-production"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="HBS CRM"
CRON_SECRET="another-random-secret-for-cron-endpoints"

# ============ COMPANY ============
COMPANY_NAME="Hover Business Services LLP"
COMPANY_SHORT="HBS"
EMPLOYEE_ID_PREFIX="HBS"

# ============ CLOUDINARY (file uploads: avatars, aadhar, client reports) ============
# Placeholders — get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_FOLDER="hbs-crm"

# ============ SMTP EMAIL (nodemailer) ============
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_NAME="HBS CRM"
SMTP_FROM_EMAIL="noreply@hoverbusinessservices.com"

# ============ WHATSAPP (waapi.hoverbusinessservices.com) ============
WHATSAPP_API_URL="http://waapi.hoverbusinessservices.com/api/sendmsgutil.php"
WHATSAPP_USER="Printhutt_BW"
WHATSAPP_PASS="123456"
WHATSAPP_SENDER="BUZWAP"

# ============ NODE ENV ============
NODE_ENV="development"

# ============ RAZORPAY (client portal + mobile app online payments) ============
